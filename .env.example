# Copia este archivo a `.env` EN EL DROPLET (NO lo commitees). Lo leen el deploy y pm2.
PORT=3400                     # Puerto local (3000/3100/3200/3300 ya ocupados; menu usa 3400)
HOST=127.0.0.1                # Siempre localhost; nginx hace el proxy reverso
ORIGIN=https://coleccionador.online   # Requerido por SvelteKit para aceptar POST/form-actions en prod
DATABASE_URL=./local.db       # Ruta del archivo SQLite (better-sqlite3 + drizzle)
# UPLOADS_DIR=./uploads       # Carpeta de archivos subidos. Default ./uploads (junto al app,
                              # persiste entre deploys). En el droplet puedes apuntarlo a un
                              # absoluto como /var/lib/menu/uploads si prefieres separarlo.
# ADMIN_PASSWORD=             # Si tu app tiene panel admin
